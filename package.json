{
  "name": "coscribe",
  "version": "1.0.0",
  "description": "CoScribe：以本地项目为核心的 AI 学习与内容工作台",
  "private": true,
  "type": "module",
  "main": "./out/main/index.js",
  "author": "UESTC-ly",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/UESTC-ly/CoScribe.git"
  },
  "homepage": "https://github.com/UESTC-ly/CoScribe#readme",
  "bugs": "https://github.com/UESTC-ly/CoScribe/issues",
  "scripts": {
    "dev": "electron-vite dev",
    "start": "electron-vite preview",
    "build": "npm run typecheck && electron-vite build",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.node.json",
    "test": "npm run test:unit && npm run test:electron && npm run test:ai",
    "test:unit": "vitest run",
    "test:electron": "vitest run --config electron/vitest.config.ts",
    "test:ai": "vitest run --config src/components/ai/vitest.ai.config.ts",
    "test:watch": "vitest",
    "test:e2e": "npm run build && playwright test",
    "dist": "npm run build && electron-builder",
    "dist:dir": "npm run build && electron-builder --dir",
    "dist:mac:arm64": "npm run build && electron-builder --mac dmg zip --arm64",
    "dist:win:x64": "npm run build && electron-builder --win nsis --x64",
    "verify:package:mac": "node scripts/verify-packaged-app.mjs release/mac-arm64/CoScribe.app",
    "verify:package:win": "node scripts/verify-packaged-windows.mjs release/win-unpacked"
  },
  "dependencies": {
    "chokidar": "^4.0.3",
    "mammoth": "^1.12.0",
    "pdfjs-dist": "^6.1.200"
  },
  "devDependencies": {
    "@codemirror/commands": "^6.8.1",
    "@codemirror/lang-markdown": "^6.3.4",
    "@paddleocr/paddleocr-js": "^0.4.2",
    "@playwright/test": "^1.55.0",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@types/katex": "^0.16.7",
    "@types/node": "^24.3.0",
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.9",
    "@uiw/react-codemirror": "^4.25.11",
    "@vitejs/plugin-react": "^5.0.2",
    "clsx": "^2.1.1",
    "dompurify": "^3.4.12",
    "electron": "^43.1.1",
    "electron-builder": "^26.0.12",
    "electron-vite": "^5.0.0",
    "highlight.js": "^11.11.1",
    "jsdom": "^26.1.0",
    "katex": "^0.16.22",
    "lucide-react": "^0.468.0",
    "mermaid": "^11.16.0",
    "pptx-svg": "^0.6.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "react-pdf": "^10.4.1",
    "rehype-katex": "^7.0.1",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "typescript": "^5.9.2",
    "vite": "^7.3.6",
    "vite-plugin-static-copy": "^3.1.2",
    "vitest": "^4.1.10",
    "zustand": "^5.0.8"
  },
  "build": {
    "appId": "com.coscribe.app",
    "productName": "CoScribe",
    "asar": true,
    "directories": {
      "output": "release"
    },
    "files": [
      "out/**/*",
      "!**/*.map",
      "package.json",
      "LICENSE",
      "THIRD_PARTY_NOTICES.md",
      "resources/ocr/LICENSE-APACHE-2.0.txt"
    ],
    "mac": {
      "category": "public.app-category.education",
      "icon": "assets/app-icon.icns",
      "target": [
        "dmg",
        "zip"
      ]
    },
    "win": {
      "target": "nsis"
    },
    "linux": {
      "category": "Education",
      "target": [
        "AppImage",
        "deb"
      ]
    }
  }
}
